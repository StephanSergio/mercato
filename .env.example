# ============================================================
# Mercato — omgevingsvariabelen
# Kopieer dit bestand naar `.env.local` en vul je eigen waarden in.
# `.env.local` staat in .gitignore en wordt NIET gecommit.
# ============================================================

# --- Firebase (Project settings > General > Your apps > SDK config) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Recepten (kies ÉÉN van de twee opties) ---

# Optie A — AANBEVOLEN: proxy via Firebase Function (sleutel blijft server-side).
# Zet dit op de URL van je gedeployde `recipe` functie, bijv.:
#   https://us-central1-<project-id>.cloudfunctions.net/recipe
# Als dit is gezet, wordt de directe sleutel hieronder genegeerd.
VITE_RECIPE_PROXY_URL=

# Optie B — SIMPEL: directe browser-aanroep.
# LET OP: deze sleutel komt mee in de browser-bundle en is dus zichtbaar
# voor iedereen die de site bezoekt. Gebruik alleen een sleutel met
# strakke limieten. Laat beide leeg om de receptenfunctie uit te zetten.
VITE_ANTHROPIC_API_KEY=
