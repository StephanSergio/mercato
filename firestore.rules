rules_version = '2';

// ============================================================
// GEDEELDE Firestore-regels — project `fitnessapp-92b38`
// ------------------------------------------------------------
// LET OP: dit Firebase-project wordt door TWEE apps gedeeld:
//   • Mercato  — geen login; het gezin deelt de lijst direct.
//   • CleanFit — wél login; data per gebruiker onder /users/{uid}.
//
// Eén project = één regelbestand. Beide repos bevatten exact deze
// regels, zodat het publiceren vanuit de ene app de andere niet
// platlegt. Pas je iets aan? Werk dan BEIDE repos bij
// (mercato/firestore.rules én CleanFit/firestore.rules) en publiceer.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Mercato — open (geen login, privé gezins-app) ──
    match /ingredients/{doc}  { allow read, write: if true; }
    match /shoppingList/{doc} { allow read, write: if true; }
    match /categories/{doc}   { allow read, write: if true; }
    match /dishVotes/{doc}    { allow read, write: if true; }
    match /weekMenu/{doc}     { allow read, write: if true; }

    // ── CleanFit — per gebruiker (vereist login) ──
    // Recursieve wildcard {document=**} dekt steps, workouts,
    // programMeta, sessionDrafts, presets, enz.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Alles wat hier niet expliciet genoemd is, blijft dicht.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
